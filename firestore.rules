rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Catch-all deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'tariqkhanpk945@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidJob(data) {
      return data.title is string && data.title.size() > 0 &&
             data.description is string && data.description.size() > 0 &&
             data.category in ['Government', 'Private', 'Overseas', 'Scholarship', 'Newspaper'] &&
             data.whatsapp is string && data.whatsapp.size() > 0;
    }

    match /jobs/{jobId} {
      allow read: if true;
      allow write: if true; 
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
